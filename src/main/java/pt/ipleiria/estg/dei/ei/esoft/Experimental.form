<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="pt.ipleiria.estg.dei.ei.esoft.Experimental">
  <grid id="27dc6" binding="painelPrincipal" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties>
      <maximumSize width="1000" height="800"/>
      <minimumSize width="300" height="200"/>
      <preferredSize width="300" height="200"/>
    </properties>
    <border type="none"/>
    <children>
      <component id="9b7be" class="javax.swing.JLabel" binding="experiencia">
        <constraints border-constraint="Center"/>
        <properties>
          <horizontalAlignment value="0"/>
          <horizontalTextPosition value="0"/>
          <text value="Experiência"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
